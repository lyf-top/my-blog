---
import { getCollection, render } from "astro:content";
import { Icon } from "astro-icon/components";
import ChangelogEditor from "@/components/edit/ChangelogEditor.svelte";
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import "@/styles/pages/changelog.css";

if (!siteConfig.pages.changelog) {
	return Astro.redirect("/404/");
}

const entries = await getCollection("changelog");

const sorted = entries.sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const entriesWithContent = await Promise.all(
	sorted.map(async (entry) => {
		const { Content } = await render(entry);
		return {
			...entry,
			Content,
		};
	}),
);

const typeConfig = {
	feature: {
		label: i18n(I18nKey.changelogFeature),
		icon: "material-symbols:rocket-launch",
		cls: "cl-feature",
	},
	improvement: {
		label: i18n(I18nKey.changelogImprovement),
		icon: "material-symbols:build",
		cls: "cl-improvement",
	},
	fix: {
		label: i18n(I18nKey.changelogFix),
		icon: "material-symbols:bug-report",
		cls: "cl-fix",
	},
	removal: {
		label: i18n(I18nKey.changelogRemoval),
		icon: "material-symbols:delete",
		cls: "cl-removal",
	},
};

const displayTitle = i18n(I18nKey.changelogTitle);
const displaySubtitle = i18n(I18nKey.changelogSubtitle);
---

<MainGridLayout title={displayTitle} description={displaySubtitle}>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-4 py-6 md:px-9 relative w-full">

      <!-- 头部 -->
      <div class="flex items-center gap-3 mb-4">
        <div class="w-12 h-12 rounded-2xl bg-black dark:bg-white flex items-center justify-center">
          <Icon name="material-symbols:history" class="text-[1.4rem] text-white dark:text-black" />
        </div>
        <div>
          <h1 data-pagefind-meta="title" data-pagefind-weight="10" class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">{displayTitle}</h1>
          <p class="text-sm text-neutral-500 dark:text-neutral-400">{displaySubtitle}</p>
        </div>
      </div>

      <!-- 编辑工具栏 -->
      <div data-no-swup>
        <ChangelogEditor client:only />
      </div>

      <!-- 分类筛选胶囊 -->
      <div class="cl-filter-bar" id="cl-filter-bar">
        <div class="tools-tab-pill" data-cl-tab-nav>
          <div class="tools-tab-indicator" data-cl-tab-indicator></div>
          <button data-cl-tab="all" class="tools-tab-btn tools-tab-btn-active">
            全部
            <span class="tools-tab-badge">{entriesWithContent.length}</span>
          </button>
          {Object.entries(typeConfig).map(([key, cfg]) => (
            <button data-cl-tab={key} class="tools-tab-btn tools-tab-btn-inactive">
              <Icon name={cfg.icon} class="text-sm" />
              <span>{cfg.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- 时间线 -->
      <div class="cl-timeline" id="cl-timeline">
        {entriesWithContent.length > 0 ? (
          entriesWithContent.map((entry) => {
            const t = typeConfig[entry.data.type];
            const dateStr = entry.data.date.toISOString().slice(0, 10);
            return (
              <article
                class={`cl-entry ${t.cls}`}
                data-type={entry.data.type}
                data-slug={entry.id}
                data-filename={entry.id}
              >
                <div class="cl-entry-dot"></div>
                <div class="cl-entry-body">
                  <div class="cl-entry-meta">
                    <time datetime={entry.data.date.toISOString()}>{dateStr}{entry.data.time ? " · " + entry.data.time : ""}</time>
                    <span class="cl-entry-version">{entry.data.version}</span>
                  </div>
                  <div class="cl-entry-card">
                    <p class="cl-entry-text">{entry.data.description}</p>
                    <div class="cl-entry-content">
                      <entry.Content />
                    </div>
                  </div>
                </div>
              </article>
            );
          })
        ) : (
          <div class="text-center py-16">
            <Icon name="material-symbols:history" class="text-5xl text-neutral-300 dark:text-neutral-600 mb-4" />
            <p class="text-neutral-500 dark:text-neutral-400">{i18n(I18nKey.changelogNoData)}</p>
          </div>
        )}
      </div>

    </div>
  </div>

  <script is:inline>
    (function() {
      function initChangelogTabs() {
        var tabNav = document.querySelector('[data-cl-tab-nav]');
        var tabButtons = document.querySelectorAll('[data-cl-tab]');
        var indicator = document.querySelector('[data-cl-tab-indicator]');
        if (!tabNav || !tabButtons.length || !indicator) return;

        var newNav = tabNav.cloneNode(true);
        if (tabNav.parentNode) tabNav.parentNode.replaceChild(newNav, tabNav);
        tabNav = newNav;
        tabButtons = tabNav.querySelectorAll('[data-cl-tab]');
        indicator = tabNav.querySelector('[data-cl-tab-indicator]');

        function updateIndicator(targetBtn) {
          if (!indicator || !targetBtn) return;
          indicator.style.left = targetBtn.offsetLeft + 'px';
          indicator.style.top = targetBtn.offsetTop + 'px';
          indicator.style.width = targetBtn.offsetWidth + 'px';
          indicator.style.height = targetBtn.offsetHeight + 'px';
          indicator.style.opacity = '1';
        }

        function activateTab(targetTab) {
          if (!targetTab) return;
          var targetButton = Array.from(tabButtons).find(function(btn) {
            return btn.dataset.clTab === targetTab;
          });
          if (!targetButton) return;

          tabButtons.forEach(function(btn) {
            btn.classList.remove('tools-tab-btn-active');
            btn.classList.add('tools-tab-btn-inactive');
            btn.disabled = false;
          });
          targetButton.classList.remove('tools-tab-btn-inactive');
          targetButton.classList.add('tools-tab-btn-active');
          targetButton.disabled = true;

          requestAnimationFrame(function() { updateIndicator(targetButton); });

          var entries = document.querySelectorAll('.cl-entry');
          entries.forEach(function(entry) {
            if (targetTab === 'all' || entry.getAttribute('data-type') === targetTab) {
              entry.classList.remove('hidden');
            } else {
              entry.classList.add('hidden');
            }
          });
        }

        tabButtons.forEach(function(button) {
          button.addEventListener('click', function() {
            var targetTab = button.dataset.clTab;
            if (targetTab) activateTab(targetTab);
          });
        });

        var activeBtn = tabNav.querySelector('.tools-tab-btn-active');
        if (activeBtn) {
          requestAnimationFrame(function() { updateIndicator(activeBtn); });
        }

        window.addEventListener('resize', function() {
          var act = tabNav.querySelector('.tools-tab-btn-active');
          if (act) updateIndicator(act);
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initChangelogTabs);
      } else {
        initChangelogTabs();
      }

      document.addEventListener('astro:page-load', initChangelogTabs);
      document.addEventListener('swup:contentReplaced', initChangelogTabs);
    })();
  </script>
</MainGridLayout>
