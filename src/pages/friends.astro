---
import { getEntry } from "astro:content";
import Comment from "@components/comment/index.astro";
import Icon from "@components/common/Icon.astro";
import FriendCard from "@components/features/FriendCard.astro";
import FriendRulesModal from "@components/features/FriendRulesModal.astro";
import PageTitle from "@/components/common/PageTitle.astro";
import FriendsEditor from "@/components/edit/FriendsEditor.svelte";
import {
	commentConfig,
	friendsPageConfig,
	getEnabledFriends,
	siteConfig,
} from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

// 检查页面是否启用
if (!siteConfig.pages.friends) {
	return Astro.redirect("/404/");
}

const friendsPost = await getEntry("spec", "friends");

if (!friendsPost) {
	throw new Error("friends page content not found");
}

// 检查评论系统是否启用
const isCommentEnabled =
	commentConfig?.type &&
	commentConfig.type !== "none" &&
	friendsPageConfig.showComment !== false;

// 使用配置文件中的友链数据，按权重排序
const items = getEnabledFriends();

// 页面标题和描述
const title = friendsPageConfig.title || i18n(I18nKey.friends);
const description =
	friendsPageConfig.description || i18n(I18nKey.friendsDescription);
---

<MainGridLayout title={title} description={description}>
  <div
    class="flex w-full rounded-(--radius-large) relative min-h-32"
  >
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <!-- 页面标题和描述 -->
      <div class="mb-4 flex justify-between items-start gap-4 flex-wrap">
        <div class="flex-1 min-w-0">
          <PageTitle title={title} eyebrow="Friends" variant="stacked" />
          {
            description && (
              <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mb-4 mt-3">
                {description}
              </p>
            )
          }
        </div>
        <div class="page-header-toolbar-slot flex-shrink-0 flex items-center gap-2 flex-wrap">
            {friendsPageConfig.applyLink && (
                <button
                  data-open-friend-rules
                  class="edit-main-btn-style rounded-lg border border-neutral-900 dark:border-neutral-100 text-neutral-900 dark:text-neutral-100 hover:bg-neutral-900 hover:text-neutral-100 dark:hover:bg-neutral-100 dark:hover:text-neutral-900 transition-colors duration-200 font-medium flex items-center gap-1.5 cursor-pointer"
                  style="display:inline-flex;align-items:center;gap:6px;padding:6px 12px;border-radius:8px;border:1px solid rgba(0,0,0,0.9);background:transparent;color:rgba(0,0,0,0.9);font-size:13px;font-weight:500;cursor:pointer;white-space:nowrap;line-height:1;height:32px;box-sizing:border-box;"
                >
                  <Icon name="material-symbols:help-outline-rounded" class="text-base" />
                  如何申请友链
                </button>
              )
            }
        </div>
      </div>

      <!-- 友链编辑器工具栏（编辑按钮 + 外部Gist友链注入） -->
      <div data-no-swup>
        <FriendsEditor client:only />
      </div>

      <!-- 友链网格（SSR 渲染本地友链） -->
      <div class="friends-grid" id="friends-grid">
        {items.map((item) => (
          <div class="friend-card" data-friend-id={item.id || item.siteurl} data-tags={item.tags?.join(",")}>
            <FriendCard
              title={item.title}
              href={item.siteurl}
              imgurl={item.imgurl}
              desc={item.desc}
              tags={item.tags}
            />
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- 评论区 -->
  {isCommentEnabled && (
    <div class="mt-4">
      <Comment post={friendsPost} customPath="/friends/" />
    </div>
  )}

  <!-- 友链申请指南弹窗 -->
  <FriendRulesModal applyLink={friendsPageConfig.applyLink} />
</MainGridLayout>

<style>
  /* 移除 EditToolbar 容器的 margin，确保按钮对齐 */
  .page-header-toolbar-slot .edit-toolbar {
    margin-bottom: 0 !important;
  }

  /* 完全复制 EditToolbar 中 .edit-main-btn 的样式 */
  .edit-main-btn-style {
    display: inline-flex !important;
    align-items: center !important;
    gap: 6px !important;
    padding: 6px 12px !important;
    border-radius: 8px !important;
    border: 1px solid rgba(0, 0, 0, 0.9) !important;
    background: transparent !important;
    color: rgba(0, 0, 0, 0.9) !important;
    font-size: 13px !important;
    font-weight: 500 !important;
    cursor: pointer !important;
    transition: background-color 0.2s, color 0.2s !important;
    white-space: nowrap !important;
    line-height: 1 !important;
    height: 32px !important;
    box-sizing: border-box !important;
  }

  .edit-main-btn-style:hover {
    background: rgba(0, 0, 0, 0.9);
    color: white;
  }

  :global(.dark) .edit-main-btn-style {
    border-color: rgba(255, 255, 255, 0.9);
    color: rgba(255, 255, 255, 0.9);
  }

  :global(.dark) .edit-main-btn-style:hover {
    background: rgba(255, 255, 255, 0.9);
    color: rgba(0, 0, 0, 0.9);
  }

  /* 确保图标垂直居中 */
  .edit-main-btn-style Icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    vertical-align: middle;
    line-height: 0;
  }

  @media (max-width: 768px) {
    :has(> .page-header-toolbar-slot) {
      flex-direction: column;
    }
    .page-header-toolbar-slot {
      width: 100%;
    }
  }
</style>
