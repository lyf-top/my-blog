---
import { Icon } from "astro-icon/components";
import Comment from "@/components/comment/index.astro";
import PageTitle from "@/components/common/PageTitle.astro";
import MomentsCover from "@/components/moments/MomentsCover.astro";
import MomentsEditor from "@/components/edit/MomentsEditor.svelte";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

import "@/styles/components/moment-card.css";
---

<MainGridLayout title="动态" description="记录生活中的点点滴滴">
  <!-- 微信朋友圈风格封面 -->
  <MomentsCover />

  <!-- 页面标题 -->
  <div class="mb-4 flex justify-between items-start gap-4 flex-wrap">
    <div class="flex-1 min-w-0">
      <PageTitle title="动态" eyebrow="Moments" variant="stacked" />
      <p class="text-base text-neutral-500 dark:text-neutral-400 leading-relaxed mt-3">记录生活中的点点滴滴</p>
    </div>
    <div class="page-header-toolbar-slot flex-shrink-0"></div>
  </div>

  <!-- 说说编辑器（Svelte 组件） -->
  <div data-no-swup>
    <MomentsEditor client:only />
  </div>

  <!-- 置顶说说（JS 动态填充） -->
  <div class="wx-pinned" id="pinned-block" style="display:none">
    <div class="wx-pinned-tag">
      <iconify-icon icon="material-symbols:push-pin"></iconify-icon>
      <span>置顶</span>
    </div>
    <div class="wx-pinned-items" id="pinned-items"></div>
  </div>

  <!-- 说说列表（JS 动态渲染） -->
  <div class="wx-feed" id="moments-feed">
    <div class="wx-loading" id="moments-loading">
      <iconify-icon icon="material-symbols:progress-activity-rounded" class="wx-loading-icon"></iconify-icon>
      <span>加载中...</span>
    </div>
  </div>

  <!-- 评论区 -->
  <div id="moments-comments">
    <Comment customPath="/moments/" />
  </div>

  <!-- 访客统计 -->
  <div class="wx-visitor">
    <Icon name="material-symbols:visibility-outline" class="wx-visitor-icon" />
    <span class="waline-count" data-path="/moments/">-</span>
    <span>次浏览</span>
  </div>
</MainGridLayout>

<script>
  // ========== 访客统计 ==========
  const countElements = document.querySelectorAll('.waline-count[data-path="/moments/"]');
  if (countElements.length > 0) {
    const serverURL = "https://co.tsh520.cn";
    fetch(serverURL + "/api/uv?path=/moments/")
      .then(res => res.json())
      .then(data => {
        const count = data.data ? data.data.unique_visitor || data.uv || 0 : (data.uv || 0);
        countElements.forEach((el: Element) => { el.textContent = String(count); });
      })
      .catch(() => {
        countElements.forEach((el: Element) => { el.textContent = "-"; });
      });
  }

  // ========== 说说客户端渲染 ==========
  const GH_OWNER = import.meta.env.PUBLIC_GITHUB_OWNER || "fqzlr";
  const GH_REPO = import.meta.env.PUBLIC_GITHUB_REPO || "my-blog";
  const MOMENTS_PATH = "public/moments.json";
  const DEFAULT_AVATAR = "https://q1.qlogo.cn/g?b=qq&nk=20447289&s=640";
  const DEFAULT_AUTHOR = import.meta.env.PUBLIC_GITHUB_OWNER || "fqzlr";

  /**
   * 通过 /api/github 代理读取 GitHub Contents API（实时，不走CDN缓存）
   * GitHub Contents API 返回 base64 编码的内容，需要解码
   */
  async function fetchMoments(): Promise<any[]> {
    const branch = (typeof window !== 'undefined' && (window as any).__DEPLOY_BRANCH__) || "master";
    const apiPath = `repos/${GH_OWNER}/${GH_REPO}/contents/${MOMENTS_PATH}?ref=${branch}`;

    const res = await fetch("/api/github", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        path: apiPath,
        method: "GET",
        headers: { Accept: "application/vnd.github+json" },
      }),
    });

    if (!res.ok) throw new Error("HTTP " + res.status);
    const data = await res.json();
    // GitHub Contents API 返回 base64 编码的 content
    const text = decodeURIComponent(escape(atob(data.content.replace(/\n/g, ""))));
    return JSON.parse(text);
  }

  function escapeHtml(str: string): string {
    if (!str) return "";
    return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  function formatTimeAgo(dateStr: string): string {
    const date = new Date(dateStr);
    if (isNaN(date.getTime())) return dateStr;
    const now = new Date();
    const diff = now.getTime() - date.getTime();
    const minutes = Math.floor(diff / 60000);
    const hours = Math.floor(diff / 3600000);
    const days = Math.floor(diff / 86400000);
    if (minutes < 1) return "刚刚";
    if (minutes < 60) return minutes + "分钟前";
    if (hours < 24) return hours + "小时前";
    if (days < 30) return days + "天前";
    const y = date.getFullYear();
    const m = String(date.getMonth() + 1).padStart(2, "0");
    const d = String(date.getDate()).padStart(2, "0");
    return `${y}-${m}-${d}`;
  }

  function getGridCols(count: number): number {
    if (count === 1) return 1;
    if (count === 2 || count === 4) return 2;
    return 3;
  }

  function renderMomentCard(m: any): string {
    const author = escapeHtml(m.author || DEFAULT_AUTHOR);
    const avatar = escapeHtml(m.avatar || DEFAULT_AVATAR);
    const content = escapeHtml(m.content || "").replace(/\n/g, "<br>");
    const time = formatTimeAgo(m.published);
    const isoTime = new Date(m.published).toISOString();

    const pinnedBadge = m.pinned
      ? '<span class="pinned-badge"><iconify-icon icon="material-symbols:pinboard" class="pinned-icon"></iconify-icon><span>置顶</span></span>'
      : "";

    const locationHtml = m.location
      ? '<span class="meta-dot">·</span><span class="location"><iconify-icon icon="material-symbols:location-on-outline" class="location-icon"></iconify-icon>' + escapeHtml(m.location) + "</span>"
      : "";

    const header = '<div class="card-header">'
      + '<div class="card-avatar"><img src="' + avatar + '" alt="' + author + '" class="avatar-img" loading="lazy" onerror="this.src=\'data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22 fill=%22%23999%22><circle cx=%2212%22 cy=%228%22 r=%224%22/><path d=%22M20 21a8 8 0 1 0-16 0%22/></svg>\'"></div>'
      + '<div class="card-user-info"><div class="user-row"><span class="user-name">' + author + "</span>" + pinnedBadge + "</div>"
      + '<div class="meta-row"><time datetime="' + isoTime + '">' + time + "</time>" + locationHtml + "</div></div></div>";

    const contentHtml = content
      ? '<div class="card-content"><div class="moment-markdown"><p>' + content + "</p></div></div>"
      : "";

    let imagesHtml = "";
    if (m.images && m.images.length > 0) {
      const cols = getGridCols(m.images.length);
      let imgItems = "";
      const maxShow = 9;
      for (let i = 0; i < m.images.length && i < maxShow; i++) {
        const img = escapeHtml(m.images[i]);
        const isLast = i === maxShow - 1 && m.images.length > maxShow;
        imgItems += '<div class="image-item">'
          + '<img src="' + img + '" alt="" class="image-img" loading="lazy" data-fancybox="gallery-' + escapeHtml(m.id) + '" data-src="' + img + '">'
          + (isLast ? '<div class="more-overlay"><span class="more-text">+' + (m.images.length - maxShow + 1) + "</span></div>" : "")
          + "</div>";
      }
      imagesHtml = '<div class="card-images image-cols-' + cols + '">' + imgItems + "</div>";
    }

    let tagsHtml = "";
    if (m.tags && m.tags.length > 0) {
      let tagItems = "";
      for (const tag of m.tags) {
        const t = escapeHtml(tag.trim());
        if (t) tagItems += '<a href="/tags/' + encodeURIComponent(t) + '/" class="tag-item">#' + t + "</a>";
      }
      tagsHtml = '<div class="card-tags">' + tagItems + "</div>";
    }

    return '<div class="wx-feed-item" data-published="' + isoTime + '">'
      + '<div id="' + escapeHtml(m.id) + '" class="moment-card group">'
      + '<div class="card-accent-bar"></div>'
      + header + contentHtml + imagesHtml + tagsHtml
      + "</div></div>";
  }

  function renderPinnedBlock(pinned: any[]) {
    const block = document.getElementById("pinned-block");
    const container = document.getElementById("pinned-items");
    if (!block || !container) return;

    if (pinned.length === 0) {
      block.style.display = "none";
      return;
    }

    block.style.display = "";
    let html = "";
    for (const m of pinned) {
      if (m.images && m.images.length > 0) {
        const cols = Math.min(m.images.length, 9);
        let imgs = "";
        for (let j = 0; j < cols; j++) {
          imgs += '<img src="' + escapeHtml(m.images[j]) + '" alt="" class="wx-pinned-img" loading="lazy">';
        }
        html += '<div class="wx-pinned-preview"><div class="wx-pimgs wx-pimgs-' + cols + '">' + imgs + "</div></div>";
      } else {
        const text = (m.content || "").slice(0, 60) + ((m.content || "").length > 60 ? "..." : "");
        html += '<div class="wx-pinned-preview"><p class="wx-ptxt">' + escapeHtml(text) + "</p></div>";
      }
    }
    container.innerHTML = html;
  }

  function renderMoments() {
    const feed = document.getElementById("moments-feed");
    if (!feed) return;

    console.log("[Moments] Fetching via GitHub API proxy");
    fetchMoments()
      .then(data => {
        if (!Array.isArray(data)) data = [];

        const pinned: any[] = [];
        const normal: any[] = [];
        for (const item of data) {
          if (item.pinned) pinned.push(item);
          else normal.push(item);
        }

        pinned.sort((a: any, b: any) => new Date(b.published).getTime() - new Date(a.published).getTime());
        normal.sort((a: any, b: any) => new Date(b.published).getTime() - new Date(a.published).getTime());

        renderPinnedBlock(pinned);

        const all = pinned.concat(normal);
        if (all.length === 0) {
          feed.innerHTML = '<div class="wx-empty" id="moments-empty">'
            + '<div class="wx-empty-icon"><iconify-icon icon="material-symbols:sentiment-neutral-outline"></iconify-icon></div>'
            + "<h3>还没有发布任何说说</h3>"
            + "<p>快去记录你的生活点滴吧</p></div>";
          return;
        }

        let html = "";
        for (const item of all) {
          html += renderMomentCard(item);
        }
        feed.innerHTML = html;

        if ((window as any).Iconify && (window as any).Iconify.scan) {
          (window as any).Iconify.scan(feed);
          const pinnedBlock = document.getElementById("pinned-block");
          if (pinnedBlock) (window as any).Iconify.scan(pinnedBlock);
        }
      })
      .catch(err => {
        console.error("[Moments] Failed to load:", err);
        feed.innerHTML = '<div class="wx-empty"><div class="wx-empty-icon"><iconify-icon icon="material-symbols:error-outline"></iconify-icon></div>'
          + "<h3>加载失败</h3><p>请稍后刷新页面重试</p></div>";
      });
  }

  // 页面加载时渲染（Astro bundled script 会在 Swup 导航后重新执行）
  renderMoments();
</script>

<style>
  /* ============================================
   * 说说列表（页面级样式）
   * ============================================ */
  .wx-feed {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1rem 0 2rem;
  }

  .wx-feed-item {
    position: relative;
  }

  .wx-feed-item + .wx-feed-item::before {
    content: '';
    position: absolute;
    top: -0.75rem;
    left: 1rem;
    right: 1rem;
    height: 1px;
    background: var(--border);
    opacity: 0.7;
  }

  /* 加载状态 */
  .wx-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 3rem 1rem;
    color: var(--content-meta);
    font-size: 0.875rem;
  }

  .wx-loading-icon {
    font-size: 1.25rem;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* 空状态 */
  .wx-empty {
    text-align: center;
    padding: 3rem 1rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .wx-empty-icon {
    width: 4rem;
    height: 4rem;
    margin: 0 auto 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--btn-regular-bg);
    border-radius: 50%;
    color: var(--content-meta);
    font-size: 2rem;
  }

  .wx-empty h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-color);
    margin-bottom: 0.375rem;
  }

  .wx-empty p {
    font-size: 0.875rem;
    color: var(--content-meta);
    margin: 0;
  }

  /* 访客统计 */
  .wx-visitor {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    margin: 1.5rem auto 0;
    padding: 0.75rem;
    color: var(--content-meta);
    font-size: 0.8125rem;
  }

  .wx-visitor-icon {
    font-size: 1rem;
  }

  /* 响应式 */
  @media (max-width: 480px) {
    .wx-feed {
      gap: 1.25rem;
      padding: 0.75rem 0 1.5rem;
    }

    .wx-feed-item + .wx-feed-item::before {
      top: -0.625rem;
      left: 0.75rem;
      right: 0.75rem;
    }
  }

  @media (max-width: 768px) {
    :has(> .page-header-toolbar-slot) {
      flex-direction: column;
    }
    .page-header-toolbar-slot {
      width: 100%;
    }
  }
</style>
