---
import PageTitle from "@/components/common/PageTitle.astro";
import ConfigEditor from "@/components/edit/ConfigEditor.svelte";
import { siteConfig } from "@/config";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

const title = "站点配置";
const description = "可视化编辑站点全局配置";
---

<MainGridLayout title={title} description={description}>
  <div class="flex w-full rounded-(--radius-large) relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <!-- 页面标题 -->
      <div class="mb-4 flex justify-between items-start gap-4 flex-wrap">
        <div class="flex-1 min-w-0">
          <PageTitle title={title} eyebrow="Config" variant="stacked" />
          <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mt-3">
            在此页面可视化编辑站点全局配置，修改后通过 GitHub API 提交到仓库。
          </p>
        </div>
        <div class="page-header-toolbar-slot flex-shrink-0"></div>
      </div>

      <!-- 配置编辑器 -->
      <ConfigEditor client:only />
    </div>
  </div>
</MainGridLayout>

<!-- 将完整 siteConfig 注入 window.__SITE_CONFIG__ -->
<script define:vars={{ siteConfig }}>
  window.__SITE_CONFIG__ = siteConfig;
</script>

<style>
  @media (max-width: 768px) {
    :has(> .page-header-toolbar-slot) {
      flex-direction: column;
    }
    .page-header-toolbar-slot {
      width: 100%;
    }
  }
</style>
