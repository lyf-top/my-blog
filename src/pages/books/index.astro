---
import { getCollection } from "astro:content";
import Comment from "@components/comment/index.astro";
import { Icon } from "astro-icon/components";
import Bookshelf from "@/components/pages/books/Bookshelf.astro";
import BangumiEditor from "@/components/edit/BangumiEditor.svelte";
import { siteConfig } from "@/config";
import { booksConfig } from "@/config/booksConfig";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { formatDateI18nWithTime } from "@/utils/date-utils";
import { removeFileExtension } from "@/utils/url-utils";

if (!siteConfig.pages.books) {
	return Astro.redirect("/404/");
}

const buildTime = formatDateI18nWithTime(new Date());

const customBangumi = await getCollection("bangumi");

// 读取 booksConfig 中编辑器保存的数据
let repoBookMap = new Map<
	string,
	{
		title?: string;
		name_cn?: string;
		status?: number;
		score?: number;
		tags?: string[];
		comment?: string;
		updated_at?: string;
	}
>();
try {
	const repoItems = booksConfig;
	repoBookMap = new Map(
		repoItems
			.filter(
				(r) =>
					r.id && r.id !== "undefined" && (r.category === "book" || r.id.includes("/book/") || r.id.startsWith("book/")),
			)
			.map((r) => {
				// 规范化 ID：将 book/xxx 转换为 /bangumi/book/xxx/ 格式
				const normalizedId = r.id.startsWith("/bangumi/") ? r.id : `/bangumi/${r.id.replace(/^\//, "")}${r.id.endsWith("/") ? "" : "/"}`;
				return [normalizedId, r];
			}),
	);
} catch (e) {
	console.error("[books] Failed to read booksConfig:", e);
}

const bookItems = customBangumi
	.filter((item) => item.data.category === "book")
	.sort((a, b) => {
		const dateA = a.data.published?.getTime() || 0;
		const dateB = b.data.published?.getTime() || 0;
		return dateB - dateA;
	})
	.map((item) => {
		const imageSrc =
			typeof item.data.image === "string"
				? item.data.image
				: item.data.image.src;
		const slug = removeFileExtension(item.id);
		const link = `/books/${slug}/`;

		return {
			title: item.data.title,
			coverImage: imageSrc,
			link,
			status: item.data.status,
			score: item.data.score || 0,
			_contentId: item.id,
		};
	});

// 用编辑器保存的数据覆盖 bookItems
for (let i = 0; i < bookItems.length; i++) {
	const repoId = `/bangumi/${bookItems[i]._contentId}/`;
	const repoItem = repoBookMap.get(repoId);
	if (repoItem) {
		bookItems[i] = {
			...bookItems[i],
			title: repoItem.title ?? bookItems[i].title,
			status: repoItem.status ?? bookItems[i].status,
			score: repoItem.score ?? bookItems[i].score,
		};
	}
}

const readingCount = bookItems.filter((b) => b.status === 3).length;
const readCount = bookItems.filter((b) => b.status === 2).length;
const wishCount = bookItems.filter((b) => b.status === 1).length;

// 转换为 BangumiEditor 可用的初始数据
const bangumiInitialItems = customBangumi
	.filter((item) => item.data.category === "book")
	.map((item) => ({
		id: `/bangumi/${item.id}/`,
		title: item.data.title,
		name_cn: item.data.name_cn || item.data.title,
		category: "book",
		status: item.data.status,
		score: item.data.score || 0,
		image:
			typeof item.data.image === "string"
				? item.data.image
				: item.data.image.src,
		tags: item.data.tags || [],
		comment: item.data.comment || "",
		updated_at: item.data.published?.toISOString() || new Date().toISOString(),
	}));

// 用编辑器保存的数据覆盖 bangumiInitialItems
for (let i = 0; i < bangumiInitialItems.length; i++) {
	const item = bangumiInitialItems[i];
	const repoItem = repoBookMap.get(item.id);
	if (repoItem) {
		bangumiInitialItems[i] = {
			...item,
			title: repoItem.title ?? item.title,
			name_cn: repoItem.name_cn ?? item.name_cn,
			status: repoItem.status ?? item.status,
			score: repoItem.score ?? item.score,
			tags: repoItem.tags ?? item.tags,
			comment: repoItem.comment ?? item.comment,
			updated_at: repoItem.updated_at ?? item.updated_at,
		};
	}
}
---

<MainGridLayout title={i18n(I18nKey.booksTitle)} description={i18n(I18nKey.booksSubtitle)}>
	<div class="books-page-wrapper flex w-full overflow-hidden relative min-h-32">
		<div data-pagefind-body class="card-base z-10 px-6 pt-8 pb-8 relative w-full">
			<!-- Page header -->
			<header class="books-header relative w-full mb-6">
				<div class="flex items-center gap-3 mb-3">
					<div class="w-12 h-12 rounded-2xl bg-black dark:bg-white flex items-center justify-center">
						<Icon name="material-symbols:auto-stories" class="text-[1.4rem] text-white dark:text-black" />
					</div>
					<div>
						<h1 data-pagefind-meta="title" data-pagefind-weight="10" class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
							{i18n(I18nKey.booksTitle)}
						</h1>
					</div>
				</div>
				<p class="text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed">
					{i18n(I18nKey.booksSubtitle)}
				</p>
				<div class="flex items-center gap-4 mt-2">
					<p class="text-xs text-neutral-400 dark:text-neutral-500">
						{i18n(I18nKey.bangumiLastUpdated)} {buildTime}
					</p>
					<div class="flex items-center gap-3 text-xs text-neutral-500 dark:text-neutral-400">
						<span class="flex items-center gap-1">
							<span class="w-2 h-2 rounded-full bg-emerald-500 inline-block"></span>
							{i18n(I18nKey.bookshelfRead)} {readCount}
						</span>
						<span class="flex items-center gap-1">
							<span class="w-2 h-2 rounded-full bg-amber-500 inline-block"></span>
							{i18n(I18nKey.bookshelfReading)} {readingCount}
						</span>
						<span class="flex items-center gap-1">
							<span class="w-2 h-2 rounded-full bg-sky-500 inline-block"></span>
							{i18n(I18nKey.bookshelfWantRead)} {wishCount}
						</span>
					</div>
				</div>
			</header>

			<div data-no-swup>
				<BangumiEditor
					client:only
					defaultCategory="book"
					customPageName="书架"
					configPath="src/config/booksConfig.ts"
					configExportName="booksConfig"
					initialItems={bangumiInitialItems}
				/>
			</div>

			<Bookshelf books={bookItems} data-section="book" />
		</div>
	</div>

	<Comment customPath="/books/" />
</MainGridLayout>
