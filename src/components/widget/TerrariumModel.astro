---
// TerrariumModel — Three.js GLB 模型展示组件
// 滚动驱动旋转，点击播放动画/音乐
---

<div
  class="terrarium-container"
  id="terrarium-canvas-container"
  data-loaded="false"
>
  <canvas id="terrarium-canvas"></canvas>
  <div class="terrarium-loading" id="terrarium-loading">
    <span class="terrarium-spinner"></span>
  </div>
</div>

<script>
  import * as THREE from "three";
  import { GLTFLoader } from "three/examples/jsm/loaders/GLTFLoader.js";
  import { DRACOLoader } from "three/examples/jsm/loaders/DRACOLoader.js";

  // Track the active instance so we can dispose it before creating a new one
  let currentDispose: (() => void) | null = null;

  function initTerrarium() {
    const container = document.getElementById(
      "terrarium-canvas-container",
    ) as HTMLElement | null;
    const canvas = document.getElementById(
      "terrarium-canvas",
    ) as HTMLCanvasElement | null;
    const loadingEl = document.getElementById(
      "terrarium-loading",
    ) as HTMLElement | null;

    // If this page doesn't contain the widget, just dispose any stale instance
    if (!container || !canvas || !loadingEl) {
      if (currentDispose) {
        currentDispose();
        currentDispose = null;
      }
      return;
    }

    // Dispose previous instance before re-initializing
    if (currentDispose) {
      currentDispose();
      currentDispose = null;
    }

    // Reset loading state
    loadingEl.style.opacity = "1";
    loadingEl.style.display = "flex";
    loadingEl.innerHTML = '<span class="terrarium-spinner"></span>';
    container.setAttribute("data-loaded", "false");

    // ── Scene setup ──────────────────────────────────
    const renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: true,
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0); // Ensure transparent background (defensive)
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.2;

    const scene = new THREE.Scene();
    scene.background = null; // Explicitly null background for transparency

    const camera = new THREE.PerspectiveCamera(35, 1, 0.1, 100);
    camera.position.set(0, 0.6, 5);
    camera.lookAt(0, -0.1, 0);

    // ── Lighting ─────────────────────────────────────
    const ambientLight = new THREE.AmbientLight(0xffffff, 1.8);
    scene.add(ambientLight);

    const keyLight = new THREE.DirectionalLight(0xffffff, 2.5);
    keyLight.position.set(2, 3, 3);
    scene.add(keyLight);

    const fillLight = new THREE.DirectionalLight(0x8899cc, 1.2);
    fillLight.position.set(-1.5, 1, -1);
    scene.add(fillLight);

    const rimLight = new THREE.DirectionalLight(0xffccaa, 1.5);
    rimLight.position.set(0, -0.5, -2);
    scene.add(rimLight);

    // ── Resize ───────────────────────────────────────
    const c = container;
    function resize() {
      const rect = c.getBoundingClientRect();
      const w = rect.width;
      const h = Math.min(w * 0.75, 420);
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      c.style.height = `${h}px`;
    }

    resize();
    window.addEventListener("resize", resize);

    // ── State ────────────────────────────────────────
    let audio: HTMLAudioElement | null = null;
    let modelGroup: THREE.Group | null = null;
    let mixer: THREE.AnimationMixer | null = null;
    let animationActions: THREE.AnimationAction[] | null = null;
    let isPlaying = false;
    let lastTime = 0;
    let animationId = 0;
    let disposed = false;

    // ── Scroll-driven rotation ───────────────────────
    // Initial: tilted to the left (negative Y rotation)
    // On scroll down: rotate right toward 0 (facing front)
    // Viewport-position-based: model stays at -45° while in lower viewport,
    // only rotates when element approaches the top of the viewport
    const INITIAL_ROTATION_Y = -Math.PI / 4; // -45deg, tilted left
    const SCROLL_ROTATION_RANGE = Math.PI / 4; // 45deg of rotation driven by scroll

    function updateScrollRotation() {
      if (!modelGroup || !container) return;

      const rect = container.getBoundingClientRect();
      const windowHeight = window.innerHeight;

      // Rotation only happens in the top 30% of the viewport
      const threshold = windowHeight * 0.3;

      let progress = 0;
      if (rect.top < threshold) {
        progress = 1 - rect.top / threshold;
      }

      modelGroup.rotation.y = INITIAL_ROTATION_Y + progress * SCROLL_ROTATION_RANGE;
    }

    // ── Click to play ───────────────────────────────
    const handleClick = () => {
      togglePlay();
    };
    canvas.addEventListener("click", handleClick);

    // ── Animation loop ──────────────────────────────
    function animate() {
      if (disposed) return;
      animationId = requestAnimationFrame(animate);

      const now = performance.now();
      const delta = lastTime ? (now - lastTime) / 1000 : 0;
      lastTime = now;
      mixer?.update(delta);

      renderer.render(scene, camera);
    }

    function togglePlay() {
      isPlaying = !isPlaying;

      if (isPlaying) {
        if (mixer && animationActions) {
          mixer.stopAllAction();
          for (const action of animationActions) {
            action.reset();
            action.play();
          }
        }

        if (!audio) {
          audio = new Audio("/assets/music/《远航星的告别》翻唱 希望你能轻松快乐地活着.m4a");
          audio.volume = 0.25;
          audio.loop = true;
        }
        audio.currentTime = 0;
        audio.play().catch(() => {});
      } else {
        mixer?.stopAllAction();
        audio?.pause();
      }
    }

    // ── Load model ───────────────────────────────────
    const loader = new GLTFLoader();
    const dracoLoader = new DRACOLoader();
    dracoLoader.setDecoderPath("https://www.gstatic.com/draco/versioned/decoders/1.5.6/");
    loader.setDRACOLoader(dracoLoader);
    const modelUrl = "/models/smol_ame_terrarium.glb";

    loader.load(
      modelUrl,
      (gltf) => {
        if (disposed) return;

        modelGroup = gltf.scene;

        if (gltf.animations && gltf.animations.length > 0) {
          mixer = new THREE.AnimationMixer(modelGroup);
          animationActions = gltf.animations.map((clip) => {
            const action = mixer!.clipAction(clip);
            action.setLoop(THREE.LoopRepeat, Infinity);
            return action;
          });
        }

        // Auto-center and scale
        const box = new THREE.Box3().setFromObject(modelGroup);
        const center = box.getCenter(new THREE.Vector3());
        const size = box.getSize(new THREE.Vector3());
        const maxDim = Math.max(size.x, size.y, size.z);
        const scale = 2.5 / maxDim;

        modelGroup.scale.setScalar(scale);
        modelGroup.position.set(
          -center.x * scale,
          -center.y * scale + 0.05,
          -center.z * scale,
        );

        scene.add(modelGroup);

        // Set initial rotation (tilted left)
        modelGroup.rotation.y = INITIAL_ROTATION_Y;

        // Hide loading
        loadingEl.style.opacity = "0";
        setTimeout(() => {
          loadingEl.style.display = "none";
        }, 400);
        container.setAttribute("data-loaded", "true");

        // Start scroll listener after model is loaded
        window.addEventListener("scroll", updateScrollRotation, { passive: true });
        updateScrollRotation();

        animate();
      },
      undefined,
      (err) => {
        console.warn("[Terrarium] Failed to load model:", err);
        loadingEl.innerHTML =
          "<span class='terrarium-error'>模型加载失败</span>";
        loadingEl.style.opacity = "1";
      },
    );

    // ── Cleanup ──────────────────────────────────────
    function dispose() {
      disposed = true;
      cancelAnimationFrame(animationId);
      canvas.removeEventListener("click", handleClick);
      window.removeEventListener("resize", resize);
      window.removeEventListener("scroll", updateScrollRotation);
      mixer?.stopAllAction();
      audio?.pause();
      renderer.dispose();
      dracoLoader.dispose();
      scene.traverse((obj) => {
        if (obj instanceof THREE.Mesh) {
          obj.geometry?.dispose();
          if (Array.isArray(obj.material)) {
            obj.material.forEach((m) => m.dispose());
          } else {
            obj.material?.dispose();
          }
        }
      });
    }

    currentDispose = dispose;
  }

  // Initial load
  initTerrarium();

  // Re-init on every Swup / Astro navigation
  document.addEventListener("astro:page-load", initTerrarium);
  document.addEventListener("swup:contentReplaced", initTerrarium);
</script>

<!-- 样式已迁移至 src/styles/widgets/terrarium-model.css -->
