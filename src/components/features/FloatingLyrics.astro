---
import Icon from "@components/common/Icon.astro";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
---

<div
	id="floating-lyrics"
	class="floating-lyrics fixed bottom-0 left-0 right-0 z-[60] translate-y-full transition-transform duration-350 ease-[cubic-bezier(0.16,1,0.3,1)] pointer-events-none"
	aria-label={i18n(I18nKey.musicFloatingLyrics)}
	role="region"
>
	<div class="lyrics-bg absolute inset-0"></div>
	<div class="lyrics-content relative flex flex-col items-center justify-center py-3 px-4 md:py-4 min-h-[56px] md:min-h-[72px]">
		<div class="lyric-prev text-xs md:text-sm truncate max-w-[90vw] md:max-w-[70vw] text-center leading-relaxed transition-all duration-200"></div>
		<div class="lyric-current text-sm md:text-base font-semibold truncate max-w-[90vw] md:max-w-[70vw] text-center leading-relaxed transition-all duration-200 cursor-pointer hover:opacity-85"></div>
		<div class="lyric-next text-xs md:text-sm truncate max-w-[90vw] md:max-w-[70vw] text-center leading-relaxed transition-all duration-200"></div>
	</div>
	<button
		class="btn-close absolute top-1/2 -translate-y-1/2 left-3 md:left-4 p-1.5 rounded-full text-neutral-400 hover:text-(--primary) hover:bg-white/10 dark:hover:bg-white/5 transition-all duration-200 pointer-events-auto"
		aria-label={i18n(I18nKey.announcementClose)}
		title={i18n(I18nKey.announcementClose)}
	>
		<Icon name="material-symbols:close-rounded" class="text-lg md:text-xl" />
	</button>
</div>

<script is:inline data-swup-ignore-script>
(function () {
	var STORAGE_KEY = "floating-lyrics-visible";
	var container = document.getElementById("floating-lyrics");
	if (!container) return;

	var ui = {
		container: container,
		prev: container.querySelector(".lyric-prev"),
		current: container.querySelector(".lyric-current"),
		next: container.querySelector(".lyric-next"),
		closeBtn: container.querySelector(".btn-close"),
	};

	var state = {
		visible: localStorage.getItem(STORAGE_KEY) !== "false",
		lyrics: [],
		currentIndex: -1,
		initialized: false,
	};

	function getManager() {
		return window.__fireflyMusic;
	}

	function updateVisibility() {
		if (state.visible && state.initialized && state.lyrics.length > 0) {
			container.classList.remove("translate-y-full");
			container.classList.add("translate-y-0", "pointer-events-auto");
		} else {
			container.classList.add("translate-y-full");
			container.classList.remove("translate-y-0", "pointer-events-auto");
		}
	}

	function updateLyricsDisplay() {
		var idx = state.currentIndex;
		var lyrics = state.lyrics;

		if (!lyrics || lyrics.length === 0) {
			ui.prev.textContent = "";
			ui.current.textContent = "";
			ui.next.textContent = "";
			return;
		}

		var prevText = idx > 0 ? lyrics[idx - 1].text : "";
		var currentText = idx >= 0 && idx < lyrics.length ? lyrics[idx].text : "";
		var nextText = idx >= 0 && idx < lyrics.length - 1 ? lyrics[idx + 1].text : "";

		// Only update if changed to avoid unnecessary reflows
		if (ui.prev.textContent !== prevText) ui.prev.textContent = prevText;
		if (ui.current.textContent !== currentText) ui.current.textContent = currentText;
		if (ui.next.textContent !== nextText) ui.next.textContent = nextText;
	}

	function syncFromManager() {
		var mgr = getManager();
		if (!mgr) return;
		var s = mgr.getState();
		if (!s.initialized) return;

		state.initialized = true;

		// Sync lyrics array if changed
		if (s.lyrics && s.lyrics !== state.lyrics) {
			state.lyrics = s.lyrics;
		}

		// Sync current index
		if (s.currentLrcIndex !== state.currentIndex) {
			state.currentIndex = s.currentLrcIndex;
			updateLyricsDisplay();
		}

		updateVisibility();
	}

	// Event listeners
	function onLrcIndex(e) {
		state.currentIndex = e.detail.index;
		updateLyricsDisplay();
		updateVisibility();
	}

	function onLyrics(e) {
		var detail = e.detail;
		if (detail.status === "loaded") {
			state.lyrics = detail.lyrics || [];
			state.currentIndex = -1;
		} else {
			state.lyrics = [];
			state.currentIndex = -1;
		}
		updateLyricsDisplay();
		updateVisibility();
	}

	function onInit() {
		state.initialized = true;
		syncFromManager();
	}

	function onTrack() {
		// Reset on track change
		state.currentIndex = -1;
		syncFromManager();
	}

	function onToggleFloatingLyrics() {
		state.visible = !state.visible;
		localStorage.setItem(STORAGE_KEY, state.visible ? "true" : "false");
		updateVisibility();
	}

	// Guard: skip if already initialized (but allow re-init after Swup replaces the DOM)
	if (container.__floatingLyricsInit) {
		// DOM was replaced by Swup, re-sync state
		syncFromManager();
		return;
	}
	container.__floatingLyricsInit = true;

	window.addEventListener("fm:lrc-index", onLrcIndex);
	window.addEventListener("fm:lyrics", onLyrics);
	window.addEventListener("fm:init", onInit);
	window.addEventListener("fm:track", onTrack);
	window.addEventListener("fm:toggle-floating-lyrics", onToggleFloatingLyrics);

	// Close button
	ui.closeBtn.addEventListener("click", function () {
		state.visible = false;
		localStorage.setItem(STORAGE_KEY, "false");
		updateVisibility();
	});

	// Click on lyrics to seek
	ui.current.addEventListener("click", function () {
		var mgr = getManager();
		if (!mgr || state.currentIndex < 0) return;
		var line = state.lyrics[state.currentIndex];
		if (line && typeof line.time === "number") {
			mgr.seekToTime(line.time);
		}
	});

	// Page visibility: pause updates when hidden
	var onVisibilityChange = function () {
		if (!document.hidden) {
			syncFromManager();
		}
	};
	document.addEventListener("visibilitychange", onVisibilityChange);

	// Swup page transition: re-sync after navigation
	document.addEventListener("astro:page-load", syncFromManager);
	document.addEventListener("swup:contentReplaced", syncFromManager);

	// Initial sync if manager already initialized
	syncFromManager();

	// Cleanup on DOM removal
	var observer = new MutationObserver(function (mutations) {
		for (var i = 0; i < mutations.length; i++) {
			var removed = mutations[i].removedNodes;
			for (var j = 0; j < removed.length; j++) {
				if (removed[j] === container || (removed[j].contains && removed[j].contains(container))) {
					window.removeEventListener("fm:lrc-index", onLrcIndex);
					window.removeEventListener("fm:lyrics", onLyrics);
					window.removeEventListener("fm:init", onInit);
					window.removeEventListener("fm:track", onTrack);
					window.removeEventListener("fm:toggle-floating-lyrics", onToggleFloatingLyrics);
					document.removeEventListener("astro:page-load", syncFromManager);
					document.removeEventListener("swup:contentReplaced", syncFromManager);
					document.removeEventListener("visibilitychange", onVisibilityChange);
					observer.disconnect();
					return;
				}
			}
		}
	});
	if (container.parentNode) {
		observer.observe(container.parentNode, { childList: true });
	}
})();
</script>

