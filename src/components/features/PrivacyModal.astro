---
import { getEntry, render } from "astro:content";
import Markdown from "@components/common/Markdown.astro";

const privacyPost = await getEntry("spec", "privacy");
let Content: Awaited<ReturnType<typeof render>>["Content"] | null = null;
if (privacyPost) {
	const rendered = await render(privacyPost);
	Content = rendered.Content;
}
---

<dialog id="privacy-modal" class="privacy-modal">
	<div class="privacy-overlay" data-close-privacy></div>
	<div class="privacy-panel">
		<div class="privacy-header">
			<h2 class="privacy-title">隐私政策</h2>
			<button class="privacy-close" data-close-privacy aria-label="关闭">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line x1="18" y1="6" x2="6" y2="18"/>
					<line x1="6" y1="6" x2="18" y2="18"/>
				</svg>
			</button>
		</div>
		<div class="privacy-body">
			{Content && (
				<Markdown class="">
					<Content />
				</Markdown>
			)}
		</div>
		<div class="privacy-footer">
			<button class="privacy-confirm-btn" data-close-privacy>我知道了</button>
		</div>
	</div>
</dialog>

<script>
	function initPrivacyModal() {
		const modal = document.getElementById('privacy-modal') as HTMLDialogElement | null;
		if (!modal) return;

		function openModal() {
			modal!.showModal();
			document.body.style.overflow = 'hidden';
		}

		function closeModal() {
			modal!.close();
			document.body.style.overflow = '';
		}

		modal.querySelectorAll('[data-close-privacy]').forEach(el => {
			el.addEventListener('click', closeModal);
		});

		modal.addEventListener('click', (e) => {
			if (e.target === modal) closeModal();
		});

		modal.addEventListener('close', () => {
			document.body.style.overflow = '';
		});

		modal.addEventListener('cancel', (e) => {
			e.preventDefault();
			closeModal();
		});

		window.addEventListener('privacy:open', () => {
			openModal();
		});

		(window as any).openPrivacyModal = openModal;
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initPrivacyModal);
	} else {
		initPrivacyModal();
	}
	document.addEventListener('astro:page-load', initPrivacyModal);
	document.addEventListener('astro:after-swap', initPrivacyModal);
</script>

<style>
	.privacy-modal {
		position: fixed;
		inset: 0;
		z-index: 99999;
		display: none;
		align-items: center;
		justify-content: center;
		padding: 1rem;
		border: none;
		background: transparent;
		width: 100%;
		height: 100%;
		max-width: 100%;
		max-height: 100%;
		overflow: visible;
	}
	.privacy-modal[open] { display: flex; }
	.privacy-modal::backdrop { background: transparent; }

	.privacy-overlay {
		position: fixed;
		inset: 0;
		background: oklch(0 0 0 / 0.5);
		backdrop-filter: blur(4px);
		z-index: -1;
		animation: privacyFadeIn 0.2s ease-out;
	}

	.privacy-panel {
		background: oklch(1 0 0);
		border: 1px solid oklch(0.85 0 0);
		border-radius: 1rem;
		box-shadow: 0 25px 50px -12px oklch(0 0 0 / 0.25);
		max-width: 40rem;
		width: 100%;
		max-height: 85vh;
		display: flex;
		flex-direction: column;
		animation: privacySlideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}
	:root.dark .privacy-panel {
		background: oklch(0.15 0 0);
		border-color: oklch(0.3 0 0);
		box-shadow: 0 25px 50px -12px oklch(0 0 0 / 0.6);
	}

	@keyframes privacyFadeIn {
		from { opacity: 0; }
		to { opacity: 1; }
	}
	@keyframes privacySlideIn {
		from { opacity: 0; transform: translateY(-0.75rem) scale(0.97); }
		to { opacity: 1; transform: translateY(0) scale(1); }
	}

	.privacy-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.25rem 1.5rem;
		border-bottom: 1px solid oklch(0.9 0 0);
		flex-shrink: 0;
	}
	:root.dark .privacy-header {
		border-color: oklch(0.28 0 0);
	}

	.privacy-title {
		font-size: 1.25rem;
		font-weight: 700;
		color: oklch(0.2 0 0);
		margin: 0;
	}
	:root.dark .privacy-title {
		color: oklch(0.9 0 0);
	}

	.privacy-close {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 0.5rem;
		border: none;
		background: transparent;
		color: oklch(0.5 0 0);
		cursor: pointer;
		transition: background 0.15s, color 0.15s;
	}
	.privacy-close:hover {
		background: oklch(0.95 0 0);
		color: oklch(0.2 0 0);
	}
	:root.dark .privacy-close {
		color: oklch(0.6 0 0);
	}
	:root.dark .privacy-close:hover {
		background: oklch(0.25 0 0);
		color: oklch(0.9 0 0);
	}
	.privacy-close svg {
		width: 1.25rem;
		height: 1.25rem;
	}

	.privacy-body {
		flex: 1;
		overflow-y: auto;
		padding: 1.5rem;
		color: oklch(0.25 0 0);
		line-height: 1.7;
	}
	:root.dark .privacy-body {
		color: oklch(0.85 0 0);
	}

	.privacy-body :global(h2) {
		font-size: 1rem;
		font-weight: 700;
		margin-top: 1.5rem;
		margin-bottom: 0.75rem;
		color: oklch(0.15 0 0);
	}
	.privacy-body :global(h2:first-child) {
		margin-top: 0;
	}
	:root.dark .privacy-body :global(h2) {
		color: oklch(0.9 0 0);
	}

	.privacy-body :global(h3) {
		font-size: 0.875rem;
		font-weight: 600;
		margin-top: 1rem;
		margin-bottom: 0.5rem;
		color: oklch(0.2 0 0);
	}
	:root.dark .privacy-body :global(h3) {
		color: oklch(0.85 0 0);
	}

	.privacy-body :global(p) {
		margin-bottom: 0.75rem;
		font-size: 0.875rem;
	}

	.privacy-body :global(ul) {
		margin-bottom: 0.75rem;
		padding-left: 1.25rem;
	}

	.privacy-body :global(li) {
		margin-bottom: 0.375rem;
		font-size: 0.875rem;
	}

	.privacy-body :global(strong) {
		font-weight: 600;
		color: oklch(0.15 0 0);
	}
	:root.dark .privacy-body :global(strong) {
		color: oklch(0.9 0 0);
	}

	.privacy-footer {
		display: flex;
		justify-content: flex-end;
		padding: 1.25rem 1.5rem;
		border-top: 1px solid oklch(0.9 0 0);
		flex-shrink: 0;
	}
	:root.dark .privacy-footer {
		border-color: oklch(0.28 0 0);
	}

	.privacy-confirm-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.625rem 1.25rem;
		border-radius: 0.625rem;
		border: none;
		background: oklch(0.2 0 0);
		color: oklch(1 0 0);
		font-size: 0.875rem;
		font-weight: 500;
		cursor: pointer;
		transition: opacity 0.15s, background 0.15s, color 0.15s;
		line-height: 1;
	}
	.privacy-confirm-btn:hover {
		opacity: 0.9;
	}
	:root.dark .privacy-confirm-btn {
		background: oklch(0.85 0 0);
		color: oklch(0.15 0 0);
	}

	@media (max-width: 640px) {
		.privacy-panel {
			max-width: calc(100% - 1.5rem);
			max-height: 90vh;
		}
		.privacy-body {
			padding: 1rem;
		}
		.privacy-header,
		.privacy-footer {
			padding: 0.875rem 1rem;
		}
	}
</style>
