---
interface Filter {
	value: string;
	label: string;
	count?: number;
}

interface Props {
	filters: Filter[];
	activeFilter: string;
	sectionId: string;
}

const { filters, activeFilter, sectionId } = Astro.props;
---

<div class="flex flex-wrap gap-1.5 mb-4">
  {filters.map((filter) => (
    <button
      class:list={[
        "px-3 py-1 rounded-full text-xs font-medium transition-all duration-200",
        {
          "bg-(--primary) text-white shadow-md": filter.value === activeFilter,
          "bg-(--btn-regular-bg) text-(--btn-content) hover:bg-(--btn-regular-bg-hover)": filter.value !== activeFilter
        }
      ]}
      data-filter={filter.value}
      data-section={sectionId}
      type="button"
    >
      {filter.label}
      {filter.count !== undefined && (
        <span class="ml-1">({filter.count})</span>
      )}
    </button>
  ))}
</div>

<script is:inline define:vars={{ sectionId }}>
  (function() {
    // Guard against multiple executions
    var guardKey = '__filterControlsInitialized_' + sectionId;
    if (window[guardKey]) return;
    window[guardKey] = true;

    function initFilterControls() {
      var filterButtons = document.querySelectorAll('[data-section="' + sectionId + '"][data-filter]');

      filterButtons.forEach(function(button) {
        button.addEventListener('click', function() {
          var filter = this.dataset.filter;
          var currentSectionId = this.dataset.section;

          // Update active filter button for this section
          var sectionButtons = document.querySelectorAll('[data-section="' + currentSectionId + '"][data-filter]');
          sectionButtons.forEach(function(btn) {
            btn.classList.remove('bg-(--primary)', 'text-white', 'shadow-md');
            btn.classList.add('bg-(--btn-regular-bg)', 'text-(--btn-content)', 'hover:bg-(--btn-regular-bg-hover)');
          });

          this.classList.remove('bg-(--btn-regular-bg)', 'text-(--btn-content)', 'hover:bg-(--btn-regular-bg-hover)');
          this.classList.add('bg-(--primary)', 'text-white', 'shadow-md');

          // Filter items
          var items = document.querySelectorAll('[data-item-section="' + currentSectionId + '"]');
          items.forEach(function(item) {
            var itemStatus = item.dataset.itemStatus;

            if (filter === 'all' || itemStatus === filter) {
              item.classList.remove('hidden');
              item.style.display = 'block';
            } else {
              item.classList.add('hidden');
              item.style.display = 'none';
            }
          });

          // Update pagination
          updatePagination(currentSectionId);
        });
      });
    }

    function updatePagination(sectionId) {
      var visibleItems = document.querySelectorAll('[data-item-section="' + sectionId + '"]:not(.hidden)');
      var pagination = document.querySelector('[data-pagination-section="' + sectionId + '"]');

      if (pagination) {
        var event = new CustomEvent('updatePagination', {
          detail: { visibleCount: visibleItems.length }
        });
        pagination.dispatchEvent(event);
      }
    }

    // Swup 兼容：页面加载和导航后都初始化
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFilterControls);
    } else {
      initFilterControls();
    }
    document.addEventListener('astro:page-load', initFilterControls);
  })();
</script>
